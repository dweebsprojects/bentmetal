<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">

    <link rel="canonical" href="https://bentmetal.ca{{ page.url }}">
    <meta property="og:url" content="https://bentmetal.ca{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Bent Metal Exteriors">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:image" content="https://bentmetal.ca/images/logos/home_logo.svg">


  <script async src="https://www.googletagmanager.com/gtag/js?id=G-H76NW6JDTQ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'wait_for_update': 500
    });

    gtag('js', new Date());
    gtag('config', 'G-H76NW6JDTQ');
  </script>


    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="https://bentmetal.ca/images/logos/home_logo.svg">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "@id": "https://bentmetal.ca/#business",
      "name": "Bent Metal Exteriors",
      "url": "https://bentmetal.ca",
      "logo": "https://bentmetal.ca/images/logos/home_logo.svg",
      "image": "https://bentmetal.ca/images/logos/home_logo.svg",
      "telephone": "+1-403-890-8442",
      "email": "info@bentmetal.ca",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Calgary",
        "addressRegion": "AB",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.0447,
        "longitude": -114.0719
      },
      "areaServed": [
        { "@type": "City", "name": "Calgary" },
        { "@type": "City", "name": "Airdrie" },
        { "@type": "City", "name": "Cochrane" },
        { "@type": "City", "name": "Chestermere" },
        { "@type": "City", "name": "Okotoks" },
        { "@type": "City", "name": "Red Deer" },
        { "@type": "City", "name": "Lethbridge" },
        { "@type": "City", "name": "Medicine Hat" },
        { "@type": "City", "name": "Sundre" },
        { "@type": "City", "name": "Brooks" },
        { "@type": "AdministrativeArea", "name": "Southern Alberta" }
      ],
      "knowsAbout": [
        "Eavestrough installation",
        "Gutter installation",
        "Gutter repair",
        "Gutter cleaning",
        "Soffit installation",
        "Fascia installation",
        "Downspout installation",
        "Leaf guard installation"
      ],
      "description": "Professional eavestrough (gutter), soffit, and fascia installation, repair, and cleaning in Calgary and Southern Alberta. Built for Alberta's climate.",
      "priceRange": "$$"
    }
    </script>

    <link rel="preload" href="/images/IMG_1277.webp" as="image" type="image/webp" media="(min-width: 768.1px)" fetchpriority="high">

    <style>
        {% include "poppins.css" %}
        {% include "style.css" %}
        {% include "header.css" %}

       {% if css_file %}
            {% include css_file %}
        {% endif %}
    </style>

    <link rel="stylesheet" href="/footer.css" media="print" onload="this.media='all'">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3.0.1/dist/cookieconsent.css" media="print" onload="this.media='all'">

    <link rel="icon" type="image/x-icon" href="/images/logos/outline_logo.png">
</head>
<body>

    {% include "header.html" %}

    <main>
        {{ content | safe }}
    </main>

    {% include "footer.html" %}

    <script src="/js/navbar.js" defer></script>
    <script src="/js/toast.js" defer></script>

    <script src="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3.0.1/dist/cookieconsent.umd.js" defer></script>
    <script src="/js/cookieconsent.js" defer></script>

    {% if js_files %}
      {% for script in js_files %}
        <script src="{{ script }}" defer></script>
      {% endfor %}
    {% endif %}

    {% if js_file %}
        <script src="{{ js_file }}" defer></script>
    {% endif %}

</body>
</html>