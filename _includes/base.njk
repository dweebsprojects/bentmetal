<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BENT METAL EXTERIORS</title>

        <link rel="canonical" href="https://bentmetal.ca{{ page.url }}">
    <meta property="og:url" content="https://bentmetal.ca{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:image" content="/images/logos/home_logo.svg">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="https://bentmetal.ca/images/logos/home_logo.svg">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "name": "BENT METAL Exteriors",
      "url": "https://bentmetal.ca",
      "logo": "",
      "telephone": "+1-403-890-8442",
      "email": "info@bentmetal.ca",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Calgary",
        "addressRegion": "AB",
        "addressCountry": "CA"
      },
      "areaServed": [
        { "@type": "City", "name": "Calgary" },
        { "@type": "City", "name": "Red Deer" },
        { "@type": "City", "name": "Lethbridge" },
        { "@type": "City", "name": "Medicine Hat" },
        { "@type": "City", "name": "Okotoks" },
        { "@type": "City", "name": "Sundre" },
        { "@type": "City", "name": "Brooks" },
        { "@type": "AdministrativeArea", "name": "Southern Alberta" }
      ],
      "description": "",
      "priceRange": "$$"
    }
    </script>

    <style>
        {% include "poppins.css" %}
        {% include "style.css" %}
        {% include "header.css" %}

       {% if css_file %}
            {% include css_file %}
        {% endif %}
    </style>

    <link rel="stylesheet" href="/footer.css" media="print" onload="this.media='all'">

    <link rel="icon" type="image/x-icon" href="/images/logos/outline_logo.png">
</head>
<body>

    {% include "header.html" %}

    <main>
        {{ content | safe }}
    </main>

    {% include "footer.html" %}

    <script src="/js/navbar.js" defer></script>

    {% if js_files %}
      {% for script in js_files %}
        <script src="{{ script }}" defer></script>
      {% endfor %}
    {% endif %}

    {% if js_file %}
        <script src="{{ js_file }}" defer></script>
    {% endif %}

</body>
</html>